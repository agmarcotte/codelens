# Server Configuration
PORT=3000
NODE_ENV=development

# API Configuration
API_PREFIX=/api/v1

# Cache Configuration
CACHE_TTL=3600
CACHE_MAX_SIZE=100

# Logging
LOG_LEVEL=info

# CORS
CORS_ORIGIN=http://localhost:5173

# File Analysis
MAX_FILE_SIZE=10485760
SUPPORTED_EXTENSIONS=.ts,.tsx,.js,.jsx,.py

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100